{
  "rules": {
    "conversations": {
      "$chatId": {
        ".read": "auth != null && (auth.uid != null)",
        ".write": "auth != null && (auth.uid != null)",
        ".validate": "newData.hasChildren(['participants', 'participantDetails'])"
      }
    },
    "messages": {
      "$chatId": {
        ".read": "auth != null && (auth.uid != null)",
        ".write": "auth != null && (auth.uid != null)",
        "$messageId": {
          ".validate": "newData.hasChildren(['senderId', 'receiverId', 'message', 'timestamp']) && newData.child('message').val().length > 0 && newData.child('message').val().length <= 1000"
        }
      }
    }
  }
} 